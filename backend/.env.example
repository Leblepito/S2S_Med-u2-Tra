# BabelFlow Backend — Environment Variables
# Kopyala: cp .env.example .env

# Whisper ASR
WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=cuda

# Azure Translator
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=southeastasia

# Azure Speech (TTS)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=southeastasia

# Redis
REDIS_URL=redis://localhost:6379

# Development
USE_MOCKS=true
LOG_LEVEL=INFO

# Glossary
GLOSSARY_MODE=passthrough

# Server
PORT=8000
CORS_ORIGINS=http://localhost:3000
